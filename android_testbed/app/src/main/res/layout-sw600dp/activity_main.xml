<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F7FB"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/headerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="얼굴 인식"
                android:textColor="#111111"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/headerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="카메라를 보고 있으면 자동으로 등록/인식이 진행됩니다."
                android:textColor="#666666"
                android:textSize="16sp" />
        </LinearLayout>

        <Button
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:text="뒤로가기" />

        <Button
            android:id="@+id/settingsButton"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:text="⚙" />

        <Button
            android:id="@+id/quitButton"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:text="종료" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="10dp"
            android:layout_weight="3"
            android:background="#FFFFFF"
            android:padding="14dp">

            <androidx.camera.view.PreviewView
                android:id="@+id/previewView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="430dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:background="#FFFFFF"
            android:padding="18dp">

            <ViewFlipper
                android:id="@+id/pageFlipper"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/monitorStatusText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="환영해요 :) 얼굴 등록 및 인식을 위해 앞을 똑바로 바라봐주세요"
                            android:textColor="#111111"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/monitorDetailText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:textColor="#666666"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/registerStartButton"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="14dp"
                            android:text="등록시작"
                            android:textSize="18sp"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/candidateContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical" />

                        <Button
                            android:id="@+id/outputNameButton"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="14dp"
                            android:enabled="false"
                            android:text="이름 출력하기"
                            android:textSize="18sp" />
                    </LinearLayout>
                </ScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/registerStatusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="얼굴 샘플을 수집 중입니다."
                        android:textColor="#111111"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/registerProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="26dp"
                        android:layout_marginTop="14dp"
                        android:max="12"
                        android:progress="0" />

                    <TextView
                        android:id="@+id/registerCountText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0 / 12"
                        android:textColor="#111111"
                        android:textSize="30sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/registerCompleteText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="얼굴등록이 완료되었어요! 이름을 입력해주세요"
                        android:textColor="#111111"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/nameInput"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="14dp"
                        android:hint="이름 입력"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:textSize="20sp" />

                    <Button
                        android:id="@+id/saveNameButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="14dp"
                        android:text="이름 저장"
                        android:textSize="20sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/outputLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="#111111"
                        android:textSize="46sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/outputSubLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:textColor="#666666"
                        android:textSize="20sp" />
                </LinearLayout>
            </ViewFlipper>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
